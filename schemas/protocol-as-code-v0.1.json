{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hummbl-dev/protocol-as-code/main/schemas/protocol-as-code-v0.1.json",
  "title": "Protocol-as-Code v0.1 Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "packetStatus",
    "protocolManifest",
    "authority",
    "protocolContract",
    "receiptRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0.1"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["seed", "v0.1-draft", "validated-example", "v0.1-packet"]
    },
    "protocolManifest": {
      "type": "object",
      "required": ["id", "title", "version", "scope"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9\\-]*/[a-z0-9][a-z0-9\\-]*$"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "scope": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["owner", "canActOnBehalfOf"],
      "properties": {
        "owner": {
          "type": "string"
        },
        "canActOnBehalfOf": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "protocolContract": {
      "type": "object",
      "required": ["protocolSource", "inputs", "actors", "steps", "checks", "completion", "receiptContract"],
      "properties": {
        "protocolSource": {
          "type": "string"
        },
        "inputs": {
          "type": "object",
          "required": ["required", "optional"],
          "properties": {
            "required": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "optional": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "actors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["role", "responsibilities", "authorityLevel"],
            "properties": {
              "role": {
                "type": "string"
              },
              "responsibilities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "authorityLevel": {
                "type": "string",
                "enum": ["read", "operate", "approve", "override"]
              }
            },
            "additionalProperties": false
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "name", "ownerRole", "action", "requiredOutcome"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9\\-]+$"
              },
              "name": {
                "type": "string"
              },
              "ownerRole": {
                "type": "string"
              },
              "action": {
                "type": "string"
              },
              "requiredOutcome": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "checks": {
          "type": "object",
          "required": ["requiredApprovals", "requiredArtifacts", "rollbackWindowMinutes"],
          "properties": {
            "requiredApprovals": {
              "type": "integer",
              "minimum": 1
            },
            "requiredArtifacts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "rollbackWindowMinutes": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "completion": {
          "type": "object",
          "required": ["successCriteria", "exitCriteria", "timeoutMinutes"],
          "properties": {
            "successCriteria": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "exitCriteria": {
              "type": "string"
            },
            "timeoutMinutes": {
              "type": "integer",
              "minimum": 1
            }
          },
          "additionalProperties": false
        },
        "receiptContract": {
          "type": "object",
          "required": ["validationSamples", "validUntil", "negativeCasesCovered"],
          "properties": {
            "validationSamples": {
              "type": "integer",
              "minimum": 1
            },
            "validUntil": {
              "type": "string",
              "format": "date-time"
            },
            "negativeCasesCovered": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "receiptRequirements": {
      "type": "object",
      "required": ["protocolSource", "version", "inputs", "actors", "steps", "checks", "completion", "review"],
      "properties": {
        "protocolSource": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "inputs": {
          "type": "string"
        },
        "actors": {
          "type": "string"
        },
        "steps": {
          "type": "string"
        },
        "checks": {
          "type": "string"
        },
        "completion": {
          "type": "string"
        },
        "review": {
          "type": "string"
        },
        "exception": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "adjacentRepos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
