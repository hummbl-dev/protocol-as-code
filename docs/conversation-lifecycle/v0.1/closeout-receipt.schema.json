{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hummbl.dev/schemas/conversation-lifecycle/v0.1/closeout-receipt.schema.json",
  "title": "Conversation Lifecycle Closeout Receipt v0.1",
  "description": "Receipt for a conversation or work-session closeout following the HUMMBL Conversation Lifecycle Protocol.",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "closeout_profile",
    "lifecycle_state",
    "capabilities_declared",
    "session_mission",
    "outcome_audit",
    "artifact_reconciliation",
    "unpreserved_value",
    "preservation_writes",
    "open_work",
    "readiness_disposition",
    "handoff_packet_ref",
    "closeout_receipt_ref",
    "invoked_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "conversation_lifecycle_closeout.v0.1"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "closeout_profile": {
      "type": "string",
      "enum": ["end_chat", "end_work_session", "session_checkpoint"]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": ["OPEN", "ACTIVE", "CHECKPOINTING", "CLOSING", "CLOSED",
               "INTERRUPTED", "ABANDONED"]
    },
    "capabilities_declared": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["chat_context_read", "connected_source_read",
                 "connected_source_write", "local_filesystem_read",
                 "local_filesystem_write", "shell_execution",
                 "git_state_read", "coordination_bus_write",
                 "durable_memory_write", "artifact_creation",
                 "artifact_verification", "automation_creation"]
      }
    },
    "session_mission": {
      "type": "string"
    },
    "outcome_audit": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "classification"],
        "properties": {
          "item": {"type": "string"},
          "classification": {
            "type": "string",
            "enum": ["completed", "in_progress", "blocked",
                     "rejected_or_reversed", "unknown_unverified"]
          },
          "claim_posture": {
            "type": "string",
            "enum": ["observed", "source_reported", "inferred",
                     "provisional", "verified", "refuted", "unresolved"]
          }
        }
      }
    },
    "artifact_reconciliation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_type", "identifier", "status"],
        "properties": {
          "artifact_type": {
            "type": "string",
            "enum": ["issue", "pr", "comment", "branch", "commit",
                     "document", "file", "email", "calendar_event",
                     "automation", "schema", "fixture", "receipt",
                     "memory_update", "other"]
          },
          "identifier": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["claimed", "confirmed", "unconfirmed",
                     "failed", "not_created"]
          },
          "evidence_ref": {"type": ["string", "null"]}
        }
      }
    },
    "unpreserved_value": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["value_type", "description"],
        "properties": {
          "value_type": {
            "type": "string",
            "enum": ["decision", "architectural_boundary", "finding",
                     "constraint", "procedure", "recommendation",
                     "risk", "actionable_work"]
          },
          "description": {"type": "string"},
          "preservation_route": {"type": ["string", "null"]}
        }
      }
    },
    "preservation_writes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["destination", "check", "result"],
        "properties": {
          "destination": {
            "type": "string",
            "enum": ["existing_issue", "existing_pr", "new_artifact",
                     "handoff_packet", "durable_memory", "chat_only"]
          },
          "check": {"type": "string"},
          "result": {
            "type": "string",
            "enum": ["PASS", "FAIL", "NOT_APPLICABLE", "UNAVAILABLE", "DECLINED"]
          },
          "evidence_ref": {"type": ["string", "null"]}
        }
      }
    },
    "open_work": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["next_action", "owner"],
        "properties": {
          "next_action": {"type": "string"},
          "owner": {"type": "string"},
          "blockers": {
            "type": "array",
            "items": {"type": "string"}
          },
          "dependency_order": {"type": ["integer", "null"]},
          "stop_conditions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "required_approvals": {
            "type": "array",
            "items": {"type": "string"}
          },
          "expiry_date": {
            "type": ["string", "null"],
            "format": "date"
          },
          "must_not_do": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "readiness_disposition": {
      "type": "string",
      "enum": ["READY_TO_RESUME", "READY_WITH_GAPS", "NOT_READY", "CHECKPOINT_ONLY"]
    },
    "disposition_reasons": {
      "type": "array",
      "items": {"type": "string"}
    },
    "missing_checks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "handoff_packet_ref": {"type": ["string", "null"]},
    "closeout_receipt_ref": {"type": ["string", "null"]},
    "invoked_at": {
      "type": "string",
      "format": "date-time"
    },
    "aar_inline": {
      "type": ["boolean", "null"]
    }
  },
  "additionalProperties": false
}
